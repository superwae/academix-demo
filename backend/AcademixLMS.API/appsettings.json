  "Support": {
    "_comment": "All new support tickets are emailed to this address. Override in appsettings.Development.json or via the SUPPORT__NOTIFYEMAIL env variable.",
    "NotifyEmail": "academix.lms.ps@gmail.com"
  },
  "Payments": {
    "_comment": "Default platform cut when no per-teacher or per-org override applies. Percent (0-100).",
    "PlatformFeePercent": 15,
    "DemoMode": true,
    "_demoModeNote": "When true, course/subscription/license payments complete instantly without Lahza. Set false to use the real gateway."
  },
  "Organizations": {
    "_comment": "Days a member invite remains valid before it expires.",
    "InviteExpiresDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "http://localhost:5176",
      "https://localhost:5173",
      "https://localhost:5174",
      "https://localhost:5175",
      "https://localhost:5176"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "AcademixLMS.API.Middleware": "Information",
        "AcademixLMS.API.Filters": "Information",
        "AcademixLMS.Application.Services": "Information",
        "AcademixLMS.Infrastructure": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId:-}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/academixlms-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{CorrelationId}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithEnvironmentName"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "EndpointWhitelist": [
      "get:/health",
      "get:/api/health"
    ],
    "ClientWhitelist": [],
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*:/api/auth/*",
        "Period": "1m",
        "Limit": 10
      }
    ],
    "QuotaExceededResponse": {
      "Content": "{{ \"message\": \"API rate limit exceeded. Please try again later.\", \"details\": \"Quota exceeded. Maximum allowed: {0} per {1}. Please retry after {2} second(s).\" }}",
      "ContentType": "application/json",
      "StatusCode": 429
    }
  },
  "Lahza": {
    "SecretKey": "sk_test_8IQdNlrZocww2KluZJbcwztSaqQupByl7",
    "PublicKey": "pk_test_dhPWjVRFeMKXgNpZprVQZL3125f1CtUDs",
    "WebhookSecret": "",
    "BaseUrl": "https://api.lahza.io",
    "Currency": "ILS",
    "CallbackBaseUrl": "http://localhost:5174"
  },
  "AllowedHosts": "*"
}